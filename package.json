{
  "name": "spawn-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "spawn(task) → isolated env + AI agent → PR",
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "packages/api",
    "packages/app",
    "packages/lib"
  ],
  "scripts": {
    "setup:pre-commit-hook": "node scripts/setup-pre-commit-hook.js",
    "build": "pnpm --filter ./packages/app build",
    "api:build": "pnpm --filter ./packages/api build",
    "api:start": "pnpm --filter ./packages/api start",
    "api:dev": "pnpm --filter ./packages/api dev",
    "api:test": "pnpm --filter ./packages/api test",
    "api:typecheck": "pnpm --filter ./packages/api typecheck",
    "check": "pnpm --filter ./packages/app check && pnpm --filter ./packages/lib typecheck",
    "changeset": "changeset",
    "changeset-publish": "node -e \"if (!process.env.NPM_TOKEN) { console.log('Skipping publish: NPM_TOKEN is not set'); process.exit(0); }\" && changeset publish",
    "changeset-version": "changeset version",
    "clone": "pnpm --filter ./packages/app build && node packages/app/dist/main.js clone",
    "open": "pnpm --filter ./packages/app build && node packages/app/dist/main.js open",
    "spawn": "pnpm --filter ./packages/app build:spawn && node packages/app/dist/src/spawn/main.js",
    "e2e": "bash scripts/e2e/run-all.sh",
    "e2e:clone-cache": "bash scripts/e2e/clone-cache.sh",
    "e2e:login-context": "bash scripts/e2e/login-context.sh",
    "e2e:opencode-autoconnect": "bash scripts/e2e/opencode-autoconnect.sh",
    "list": "pnpm --filter ./packages/app build && node packages/app/dist/main.js list",
    "dev": "pnpm --filter ./packages/app dev",
    "lint": "pnpm --filter ./packages/app lint && pnpm --filter ./packages/lib lint",
    "lint:tests": "pnpm --filter ./packages/app lint:tests",
    "lint:effect": "pnpm --filter ./packages/app lint:effect && pnpm --filter ./packages/lib lint:effect",
    "test": "pnpm --filter ./packages/app test && pnpm --filter ./packages/lib test",
    "typecheck": "pnpm --filter ./packages/app typecheck && pnpm --filter ./packages/lib typecheck",
    "start": "pnpm --filter ./packages/app start"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konard/spawn.git"
  },
  "bugs": {
    "url": "https://github.com/konard/spawn/issues"
  },
  "homepage": "https://github.com/konard/spawn#readme",
  "license": "ISC",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild",
      "node-pty"
    ],
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "msgpackr-extract",
      "unrs-resolver"
    ]
  }
}
